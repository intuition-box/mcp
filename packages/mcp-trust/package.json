{
  "name": "@intuition-box/mcp-trust",
  "version": "1.2.0",
  "description": "Transitive trust reputation engine for Intuition Protocol",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider tsx src/index.ts",
    "sync": "cross-env NODE_OPTIONS=--openssl-legacy-provider tsx src/indexer/sync.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "intuition",
    "trust",
    "reputation",
    "neo4j",
    "graph"
  ],
  "author": "Ludarep",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "graphql-request": "^6.1.0",
    "neo4j-driver": "^5.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
