# Intuition API Configuration (MAINNET)
NEXT_PUBLIC_INTUITION_API_URL=https://api.intuition.systems
NEXT_PUBLIC_INTUITION_GRAPH_URL=https://mainnet.intuition.sh/v1/graphql
INTUITION_API_KEY=your_api_key_here

# Intuition Mainnet Blockchain Configuration
# Note: GraphQL API queries mainnet data, blockchain is on mainnet (Chain 1155)
NEXT_PUBLIC_CHAIN_ID=1155
NEXT_PUBLIC_RPC_URL=https://rpc.intuition.systems/http
NEXT_PUBLIC_EXPLORER_URL=https://explorer.intuition.systems
NEXT_PUBLIC_CHAIN_NAME=Intuition Mainnet
NEXT_PUBLIC_CURRENCY_NAME=TRUST
NEXT_PUBLIC_CURRENCY_SYMBOL=TRUST
NEXT_PUBLIC_CURRENCY_DECIMALS=18

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# MCP Server Configuration
MCP_SERVER_PORT=3001
# MCP Server URLs (defaults to localhost if not set - zero config for local dev)
NEXT_PUBLIC_MCP_GENERAL_URL=http://localhost:3001
NEXT_PUBLIC_MCP_TRUST_URL=http://localhost:3002
# Production URLs (uncomment and set when deploying to Intuition Box):
# NEXT_PUBLIC_MCP_GENERAL_URL=https://mcp-general.intuition.box
# NEXT_PUBLIC_MCP_TRUST_URL=https://mcp-trust.intuition.box